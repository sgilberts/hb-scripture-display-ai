{
  "name": "hallelujahbeamer-app",
  "version": "0.1.0",
  "description": "Cross-platform scripture and lyrics presentation app built with Electron, React, TypeScript, Tailwind CSS, Vite, and SQLite3.",
  "main": "dist/main/main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build src/renderer",
    "build": "npm run build:main && npm run build:renderer",
    "postinstall": "electron-rebuild -f -w deepspeech || true && node scripts/ci/auto-fetch-deepspeech-artifact.js || true",
    "set-github-artifact-token": "node scripts/ci/store-github-token.js",
    "auto-fetch-deepspeech-artifact": "node scripts/ci/auto-fetch-deepspeech-artifact.js",
    "fetch-deepspeech-artifact": "node scripts/ci/fetch-deepspeech-artifact.js",
    "start": "npm run build && cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "@aws-sdk/client-polly": "^3.366.0",
    "deepspeech": "^0.9.3",
    "keytar": "^7.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "electron": "^35.5.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.hallelujahbeamer.app",
    "productName": "HallelujahBeamer",
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
